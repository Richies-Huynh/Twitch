# Default: no .env needed — run `python -m overlay.main` for simulated chat (MVP).

# Optional: OpenAI for fake chat lines (`python -m overlay.main --ai`)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_CHAT_INTERVAL_SEC=4

# Optional: real Twitch IRC (`python -m overlay.main --live`)
# TWITCH_NICK=your_bot_username
# TWITCH_TOKEN=oauth:your_token_here
# TWITCH_CHANNEL=#your_channel

CAMERA_INDEX=0

# Optional IRC overrides (defaults: TLS on 6697)
# TWITCH_IRC_HOST=irc.chat.twitch.tv
# TWITCH_IRC_PORT=6697
# TWITCH_IRC_USE_TLS=1

# Optional capture tuning
# CAPTURE_WIDTH=1280
# CAPTURE_HEIGHT=720
# CAPTURE_FPS=30
